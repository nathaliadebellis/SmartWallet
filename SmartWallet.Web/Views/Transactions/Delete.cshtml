@model SmartWallet.Application.DTOs.FinancialTransactions.FinancialTransactionDto

@{
    ViewData["Title"] = "Excluir Transação";
}

<div class="container">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="bi bi-trash"></i>
            Excluir Transação
        </h1>

        <a asp-action="Index"
           class="btn btn-outline-secondary">
            Voltar
        </a>
    </div>

    <div class="card shadow-sm">

        <div class="card-body">

            <div class="alert alert-warning" role="alert">
                <i class="bi bi-exclamation-triangle"></i>
                Tem certeza de que deseja excluir esta transação?
                Esta ação não poderá ser desfeita.
            </div>

            <dl class="row">

                <dt class="col-sm-3">
                    Descrição
                </dt>

                <dd class="col-sm-9">
                    @Model.Description
                </dd>

                <dt class="col-sm-3">
                    Valor
                </dt>

                <dd class="col-sm-9">
                    @Model.Amount.ToString("C")
                </dd>

                <dt class="col-sm-3">
                    Data
                </dt>

                <dd class="col-sm-9">
                    @Model.TransactionDate.ToString("dd/MM/yyyy")
                </dd>

                <dt class="col-sm-3">
                    Tipo
                </dt>

                <dd class="col-sm-9">
                    @(Model.Type == SmartWallet.Domain.Enums.TransactionType.Income
                        ? "Receita"
                        : "Despesa")
                </dd>

                <dt class="col-sm-3">
                    Categoria
                </dt>

                <dd class="col-sm-9">
                    @Model.CategoryName
                </dd>

                @if (!string.IsNullOrWhiteSpace(Model.Notes))
                {
                    <dt class="col-sm-3">
                        Observações
                    </dt>

                    <dd class="col-sm-9">
                        @Model.Notes
                    </dd>
                }

            </dl>

            <form asp-action="Delete"
                  asp-route-id="@Model.Id"
                  method="post">

                <button type="submit"
                        class="btn btn-danger">
                    <i class="bi bi-trash"></i>
                    Confirmar Exclusão
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Cancelar
                </a>

            </form>

        </div>

    </div>

</div>